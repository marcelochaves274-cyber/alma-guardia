rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow a user to read and write only to documents and subcollections
    // within their own user-specific directory.
    match /sgs_genius/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
