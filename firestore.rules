
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que um usuário autenticado leia e escreva apenas
    // nos documentos dentro da subcoleção 'settings' dele.
    match /users/{userId}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra específica para os tipos de ocorrência
    match /users/{userId}/settings/occurrenceTypes {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
