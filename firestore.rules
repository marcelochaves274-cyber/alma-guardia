
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra geral que permite a um usuário autenticado ler e escrever 
    // em qualquer documento/coleção dentro de seu próprio diretório de usuário.
    // Ex: /users/{userId}/...
    match /users/{userId}/{path=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
