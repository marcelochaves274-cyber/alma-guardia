rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite leitura pública para o favicon.png para que os navegadores possam acessá-lo.
    match /favicon.png {
      allow read;
    }

    // Permite que qualquer usuário autenticado possa sobrescrever o favicon.
    // Em um app multi-usuário, isso seria mais restrito.
    match /favicon.png {
      allow write: if request.auth != null;
    }

    // Permite que usuários autenticados leiam e gravem arquivos
    // em seu próprio diretório dentro da pasta 'notices'.
    match /notices/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
