
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer usuário autenticado possa ler e escrever
    // arquivos de mapa em seu próprio diretório de usuário.
    // Esta regra é crucial para o upload dos mapas.
    match /maps/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Permite que usuários autenticados leiam e gravem arquivos
    // em seu próprio diretório dentro da pasta 'notices'.
    match /notices/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras públicas (se houver) devem vir por último
    // Ex: permitir leitura pública de uma logo da empresa.
    // match /public/{allPaths=**} {
    //   allow read;
    // }
  }
}
