
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer usuário autenticado possa ler e escrever
    // arquivos de mapa em seu próprio diretório de usuário.
    match /maps/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Permite que usuários autenticados leiam e gravem arquivos
    // em seu próprio diretório dentro da pasta 'notices'.
    match /notices/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra pública para a logo da empresa (se aplicável).
    // Permite que qualquer pessoa (mesmo não autenticada) leia a logo.
    // Isso é útil se a URL da logo for usada em locais públicos.
    // Se a logo for sempre um data URL, esta regra não é estritamente necessária,
    // mas é uma boa prática para URLs de storage públicas.
    match /public/logo/{fileName} {
       allow read;
    }
  }
}
